{
    "name": "codebar-ag/laravel-feature-policy",
    "description": "Permissions-Policy (Feature-Policy) header builder and middleware for Laravel",
    "keywords": [
        "laravel",
        "permissions-policy",
        "feature-policy",
        "security",
        "headers"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Codebar Solutions AG",
            "homepage": "https://www.codebar.ch"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "laravel/framework": "^13.3",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "CodebarAg\\LaravelFeaturePolicy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodebarAg\\LaravelFeaturePolicy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodebarAg\\LaravelFeaturePolicy\\LaravelFeaturePolicyServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage"
    },
    "version": "1.0.0"
}
