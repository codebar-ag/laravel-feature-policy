{
    "name": "codebar-ag/laravel-feature-policy",
    "description": "Permissions-Policy (Feature-Policy) header builder and middleware for Laravel",
    "keywords": [
        "codebar-ag",
        "laravel",
        "permissions-policy",
        "feature-policy",
        "security",
        "headers"
    ],
    "homepage": "https://github.com/codebar-ag/laravel-feature-policy",
    "license": "MIT",
    "authors": [
        {
            "name": "Sebastian Bürgin-Fix",
            "email": "helpdesk@codebar.ch",
            "homepage": "https://www.codebar.ch",
            "role": "Software-Engineer"
        }
    ],
    "require": {
        "php": "8.3.*|8.4.*|8.5.*",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "CodebarAg\\LaravelFeaturePolicy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodebarAg\\LaravelFeaturePolicy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodebarAg\\LaravelFeaturePolicy\\LaravelFeaturePolicyServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "ext-pcov": "For composer test-coverage (or use Xdebug with coverage mode)"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=100",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan",
        "quality": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}
